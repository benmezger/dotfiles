{{- if .secrets -}}
{{ onepasswordRead (join "/" (list .onepassword.ssh "config")) }}
{{- end -}}

Host *
    AddKeysToAgent yes
    ForwardAgent yes
    IdentityFile ~/.ssh/id_ed25519
{{- if eq .chezmoi.os "darwin" }}
    UseKeychain yes
Match exec "test -S '~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock' && [ -z \"$SSH_CONNECTION\" ]"
    IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
{{- else }}
Match exec "test -S ~/.1password/agent.sock && [ -z \"$SSH_CONNECTION\" ]"
    IdentityAgent "~/.1password/agent.sock"
{{- end }}
